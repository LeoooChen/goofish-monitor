# Copy this file to .env on the server and change this value.
GOOFISH_ADMIN_PASSWORD=change-this-long-random-password

# Advanced: instead of GOOFISH_ADMIN_PASSWORD, you may set GOOFISH_ADMIN_PASSWORD_HASH.
# Generate it after installing the Python package:
# python -c 'from backend.app.auth import hash_password; import getpass; print(hash_password(getpass.getpass("Password: ")))'
# GOOFISH_ADMIN_PASSWORD_HASH=scrypt$...

# Optional but recommended. Generate one with:
# openssl rand -base64 48
GOOFISH_SESSION_SECRET=change-this-long-random-session-secret

# Cloud servers usually do not have an XServer, so keep Chromium headless.
GOOFISH_BROWSER_HEADLESS=true
